{
  "name": "y",
  "version": "0.0.2",
  "description": "y — a self-modifying coding-agent desktop app",
  "main": "./out/main/index.js",
  "author": "",
  "homepage": "",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "dev:hexclave": "hexclave dev --config-file ./hexclave.config.ts -- pnpm dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "release:mac": "electron-vite build && electron-builder --mac --publish never && node scripts/notarize-dmg.mjs && node scripts/finalize-mac-release.mjs && node scripts/verify-mac-release.mjs",
    "build:linux": "electron-vite build && electron-builder --linux",
    "test:ui": "playwright test",
    "test:desktop": "npm run build:unpack && playwright test -c playwright.desktop.config.ts",
    "test:desktop:current": "playwright test -c playwright.desktop.config.ts",
    "test:ui:report": "playwright show-report"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@hexclave/react": "^1.0.23",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9",
    "esbuild": "^0.28.0",
    "highlight.js": "^11.11.1",
    "node-pty": "^1.1.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@hexclave/cli": "^1.0.23",
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "esbuild",
      "node-pty"
    ]
  }
}
