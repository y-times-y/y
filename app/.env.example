# Hexclave client config for the onboarding sign-in flow.
# Local development should prefer: pnpm dev:hexclave
# That runs the Hexclave local dashboard and injects HEXCLAVE_PROJECT_ID automatically.
HEXCLAVE_PROJECT_ID=
VITE_HEXCLAVE_PROJECT_ID=
HEXCLAVE_API_URL=https://api.hexclave.com
VITE_HEXCLAVE_API_URL=https://api.hexclave.com
# Usually not required unless the Hexclave project enables requirePublishableClientKey.
HEXCLAVE_PUBLISHABLE_CLIENT_KEY=
VITE_HEXCLAVE_PUBLISHABLE_CLIENT_KEY=

# Cloudflare Worker endpoints.
# Feedback defaults to https://ytimesy.com/api/feedback when unset.
Y_FEEDBACK_URL=https://ytimesy.com/api/feedback
VITE_Y_FEEDBACK_URL=https://ytimesy.com/api/feedback

# PostHog product analytics. These events are mandatory but schema-limited in main.
POSTHOG_PROJECT_API_KEY=
VITE_POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional Cloudflare copies for product-owned records.
Y_ANALYTICS_URL=https://ytimesy.com/api/events
VITE_Y_ANALYTICS_URL=https://ytimesy.com/api/events
Y_BRICK_REQUESTS_URL=https://ytimesy.com/api/brick-requests
VITE_Y_BRICK_REQUESTS_URL=https://ytimesy.com/api/brick-requests
